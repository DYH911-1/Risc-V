regs	phase1/rtl/regs.v	/^    reg[31:0] regs[0:31];$/;"	r	module:regs
regs	phase1/rtl/regs.v	/^module regs($/;"	m
regs_inst	phase1/rtl/open_risc_v.v	/^    regs regs_inst($/;"	i	module:open_risc_v	typeref:module:regs
regs_rs1_data_o	phase1/rtl/open_risc_v.v	/^    wire [31:0] regs_rs1_data_o ;$/;"	n	module:open_risc_v
regs_rs2_data_o	phase1/rtl/open_risc_v.v	/^    wire [31:0] regs_rs2_data_o ;$/;"	n	module:open_risc_v
rom	phase1/rtl/rom.v	/^module rom($/;"	m
rom_inst	phase1/tb/open_risc_v_soc.v	/^    rom rom_inst($/;"	i	module:open_risc_v_soc	typeref:module:rom
rom_inst_i	phase1/rtl/ifetch.v	/^	input  wire[31:0] rom_inst_i   ,$/;"	p	module:ifetch
rom_inst_o	phase1/tb/open_risc_v_soc.v	/^    wire [31:0] rom_inst_o;$/;"	n	module:open_risc_v_soc
rom_mem	phase1/rtl/rom.v	/^    reg[31:0] rom_mem[0:4065];\/\/4095个 32bit的空间$/;"	r	module:rom
rs1	phase1/rtl/ex.v	/^	wire[4:0] rs1;$/;"	n	module:ex
rs1	phase1/rtl/id.v	/^    wire[4:0] rs1;$/;"	n	module:id
rs1_addr_o	phase1/rtl/id.v	/^	output reg[4:0] rs1_addr_o,$/;"	p	module:id
rs1_data_i	phase1/rtl/id.v	/^	input wire[31:0] rs1_data_i,$/;"	p	module:id
rs2	phase1/rtl/ex.v	/^	wire[4:0] rs2;$/;"	n	module:ex
rs2	phase1/rtl/id.v	/^    wire[4:0] rs2;$/;"	n	module:id
rs2_addr_o	phase1/rtl/id.v	/^	output reg[4:0] rs2_addr_o,$/;"	p	module:id
rs2_data_i	phase1/rtl/id.v	/^	input wire[31:0] rs2_data_i,$/;"	p	module:id
