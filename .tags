rst	phase1/rtl/id_ex.v	/^	input wire rst,$/;"	p	module:id_ex
rst	phase1/rtl/if_id.v	/^	input wire rst,$/;"	p	module:if_id
rst	phase1/rtl/open_risc_v.v	/^    input  wire         rst       ,$/;"	p	module:open_risc_v
rst	phase1/rtl/pc_reg.v	/^    input wire       rst,$/;"	p	module:pc_reg
rst	phase1/rtl/regs.v	/^	input wire rst,$/;"	p	module:regs
rst	phase1/tb/open_risc_v_soc.v	/^    input  wire         rst     $/;"	p	module:open_risc_v_soc
rst	phase1/tb/tb.v	/^	reg rst;$/;"	r	module:tb
set_data	phase1/rtl/dff_set.v	/^	input wire [DW-1:0] set_data,  \/\/ 复位时输出的值（空指令\/0）$/;"	p	module:dff_set
tb	phase1/tb/tb.v	/^module tb;$/;"	m
